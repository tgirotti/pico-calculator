.thumb_func
.global init_i2c

init_i2c
	push{lr}
	//save link register since calls are going to be made 

	//set pin 4 to i2c func
	ldr r0, =4 //pin 4
	mov r1, #3 //func 3 -> gpio_func_i2c

	//pin 5 to i2c func
	ldr r0, =5
	mov r1, #3 //func 3 -> gpio_func_i2c

	//i2c0 @ 100k Hz
	ldr r0, =0x40044000  // adr of i2c0_inst
	ldr r1, =100000
	bl i2x_init

	pop {pc}
